# ── Required ───────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
GITHUB_ACCESS_TOKEN="ghp_..."

# ── Optional (with defaults) ───────────────────────────────────────────
# OPENAI_MODEL="gpt-4o-mini"           # LLM model (gpt-4o, gpt-4o-mini, etc.)
# RAG_TOP_K="5"                        # Number of RAG chunks to retrieve
# RAG_CONFIDENCE_THRESHOLD="0.50"      # Minimum confidence to show citations (0.0-1.0)
# RAG_LOGIT_BIAS="8.0"                 # Sigmoid bias for confidence calibration
# MAX_HISTORY_MESSAGES="10"            # Sliding window size for conversation history
# GITHUB_FILE_MAX_CHARS="5000"         # Max chars to read from GitHub files